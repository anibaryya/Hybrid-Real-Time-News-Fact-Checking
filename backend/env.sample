# Copy to .env and fill in values

# Required: PostgreSQL (e.g. docker compose -f ../docker-compose.yml up -d)
DATABASE_URL=postgresql://veritai:veritai@localhost:5432/veritai

FLASK_SECRET_KEY=change-me
GROQ_API_KEY=
NEWS_API_KEY=
GNEWS_API_KEY=
SERPER_API_KEY=

# Email OTP (Brevo Transactional Email API)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@example.com
BREVO_SENDER_NAME=VeritAI

# If email cannot be sent, the API still returns dev_otp in JSON for testing.
# AUTH_DEBUG_OTP=1

# SMS (optional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Google Sign-In (optional)
# GOOGLE_CLIENT_ID=

# OCR on Windows if Tesseract is not on PATH
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
